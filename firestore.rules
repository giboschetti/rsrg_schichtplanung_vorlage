rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isProjectMember() {
      return isSignedIn() && (
        (resource.data.memberIds is list && uid() in resource.data.memberIds)
        || resource.data.ownerId == uid()
      );
    }

    match /projects/{projectId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerId == uid()
        && request.resource.data.memberIds is list
        && uid() in request.resource.data.memberIds;
      allow read, update: if isProjectMember();
      allow delete: if isSignedIn() && resource.data.ownerId == uid();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && userId == uid();
    }
  }
}
